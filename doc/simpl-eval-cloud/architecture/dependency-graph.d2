# SIMPL-Open Dependency Graph for FVH SIMPL-Eval ApplicationSet
# Sources:
#   - docs/simpl-open/sbom/charts.yaml (chart deps + parent umbrella relations)
#   - argocd/applicationsets/simpl-eval/apps/*.yaml (runtime service refs)
#   - docs/simpl-open/sbom/audit/secrets-coupling.md (vault + ext-secret edges)

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 1
    pad: 30
  }
}

direction: right

classes: {
  fvh-internal: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
      font-color: "#1565c0"
      border-radius: 8
    }
  }
  simpl-deployed: {
    style: {
      fill: "#fff8e1"
      stroke: "#f57f17"
      font-color: "#f57f17"
      border-radius: 8
    }
  }
  simpl-undeployed: {
    style: {
      fill: "#fafafa"
      stroke: "#9e9e9e"
      font-color: "#9e9e9e"
      stroke-dash: 4
      border-radius: 8
    }
  }
  third-party: {
    style: {
      fill: "#f3e5f5"
      stroke: "#6a1b9a"
      font-color: "#6a1b9a"
      border-radius: 8
    }
  }
  external-infra: {
    style: {
      fill: "#e8f5e9"
      stroke: "#2e7d32"
      font-color: "#2e7d32"
      border-radius: 8
    }
  }
  ec-blocker: {
    shape: hexagon
    style: {
      fill: "#ffebee"
      stroke: "#c62828"
      font-color: "#c62828"
    }
  }
}

# ==========================
# External Infrastructure
# ==========================
ext: External Infrastructure {
  gcp-sql: GCP Cloud SQL\n<cloud-sql-instance> {
    shape: cylinder
    class: external-infra
  }
  gcp-kms: GCP KMS\n<openbao-keyring> {
    class: external-infra
  }
  gcp-sm: GCP Secret Manager {
    class: external-infra
  }
  ghcr: GHCR\nghcr.io/forumviriumhelsinki {
    class: external-infra
  }
  ec-registry: EC Private Registry\nregistry.code.europa.eu {
    class: ec-blocker
  }
  ec-charts: EC GitLab Helm\ncode.europa.eu/api {
    class: external-infra
  }
}

# ==========================
# simpl-eval-common namespace
# ==========================
common: simpl-eval-common namespace {
  bridge-secrets: bridge-secrets\n(FVH chart) {class: fvh-internal}
  cloudsql-proxy-c: cloudsql-proxy\n(FVH chart) {class: fvh-internal}
  openbao: OpenBao\n0.19.1 {class: third-party}
  openbao-config: openbao-config\n1.3.0 (FVH fork) {class: simpl-deployed}
  vswh: vault-secrets-webhook\n1.22.1 {class: third-party}
  confluent-op: confluent-operator\n0.1351.24 {class: third-party}
  kafka: kafka (SIMPL)\n1.2.0 {class: simpl-deployed}
  notification: notification\n2.1.1 {class: simpl-deployed}
  icm: icm\n2.3.1 {class: simpl-deployed}
  redpanda: redpanda-console\n3.2.0 {class: third-party}
  mailpit: mailpit\n0.23.1 {class: third-party}
  pgadmin: pgadmin\n1.50.0 {class: third-party}
}

# ==========================
# simpl-eval-governance namespace
# ==========================
gov: simpl-eval-governance namespace {
  cloudsql-proxy-g: cloudsql-proxy\n(FVH chart) {class: fvh-internal}
  ejbca-rest-secret: ejbca-rest-api-secret\n(ExternalSecret) {class: fvh-internal}
  redis: redis (bitnami)\n19.6.0 {class: third-party}
  keycloak: keycloakx\n7.1.8 {class: third-party}
  ejbca: ejbca\n1.0.7 {class: third-party}
  identity: identity-provider\n2.8.0 {class: simpl-deployed}
  authn: authentication-provider\n2.8.0 {class: simpl-deployed}
  onboarding: onboarding\n2.8.1 {class: simpl-deployed}
  sap: sap (security-attributes)\n2.8.0 {class: simpl-deployed}
  users-roles: users-roles\n2.8.0 {class: simpl-deployed}
  fc-service: fc-service (xsfc)\n1.0.12 {class: simpl-deployed}
  schema-mgr: schema-manager\n0.0.13 {class: simpl-deployed}
  adapter: adapter (poc-charts)\n1.0.14 {class: simpl-deployed}
  tier1: tier1-gateway\n2.8.0 {class: simpl-deployed}
  tier2gw: tier2-gateway\n2.8.0 {class: simpl-deployed}
  tier2px: tier2-proxy\n1.2.1 {class: simpl-deployed}
  frontend: simpl-fe (frontend)\n2.7.1 {class: simpl-deployed}
}

# ==========================
# Upstream-only (NOT deployed)
# ==========================
undeployed: Upstream-only (FVH skips) {
  pg-cluster: pg-cluster\n(replaced by Cloud SQL) {class: simpl-undeployed}
  openbao-init: openbao-init\n(replaced by bridge-secrets) {class: simpl-undeployed}
  eck-monitoring: eck-monitoring\n(monitoring.enabled=false) {class: simpl-undeployed}
  eck-operator: eck-operator + CRDs\n(monitoring.enabled=false) {class: simpl-undeployed}
  postgres-op: postgres-operator\n(needed only for pg-cluster) {class: simpl-undeployed}
  fe-charts: fe-* charts (5)\n(FVH uses simpl-fe instead) {class: simpl-undeployed}
  schema-ui: schema-manager-ui\n(FVH skips) {class: simpl-undeployed}
}

# ==========================
# Wave 1 -> 2 -> 3 secrets bootstrap chain
# ==========================
common.openbao -> ext.gcp-kms: auto-unseal
common.bridge-secrets -> ext.gcp-sm: ExternalSecret (postgres pw)
common.openbao-config -> common.openbao: seeds engines + roles
common.vswh -> common.openbao: validates pod annotations

# ==========================
# Cloud SQL connectivity (one proxy per ns)
# ==========================
common.cloudsql-proxy-c -> ext.gcp-sql: IAM authn (proxy)
gov.cloudsql-proxy-g -> ext.gcp-sql: IAM authn (proxy)

# All governance Java services -> Cloud SQL via the local proxy
gov.identity -> gov.cloudsql-proxy-g: jdbc
gov.authn -> gov.cloudsql-proxy-g: jdbc
gov.onboarding -> gov.cloudsql-proxy-g: jdbc
gov.sap -> gov.cloudsql-proxy-g: jdbc
gov.users-roles -> gov.cloudsql-proxy-g: jdbc
gov.keycloak -> gov.cloudsql-proxy-g: jdbc
gov.fc-service -> gov.cloudsql-proxy-g: jdbc

# ==========================
# Kafka (cross-namespace)
# ==========================
common.confluent-op -> common.kafka: operator manages CR
gov.authn -> common.kafka: producer (iaa.gov.* prefix)
gov.users-roles -> common.kafka: producer/consumer
gov.onboarding -> common.kafka: producer
common.notification -> common.kafka: consumer
common.icm -> common.kafka: producer
common.redpanda -> common.kafka: console UI

# ==========================
# Vault sidecar injection (vswh)
# ==========================
gov.adapter -> common.openbao: vault-agent sidecar
gov.fc-service -> common.openbao: vault-agent sidecar
gov.schema-mgr -> common.openbao: vault-agent sidecar
gov.identity -> common.openbao: vault-agent sidecar
gov.authn -> common.openbao: vault-agent sidecar
gov.sap -> common.openbao: vault-agent sidecar
gov.users-roles -> common.openbao: vault-agent sidecar
gov.onboarding -> common.openbao: vault-agent sidecar
common.icm -> common.openbao: vault-agent sidecar
common.notification -> common.openbao: vault-agent sidecar

# ==========================
# Keycloak/EJBCA chain (governance)
# ==========================
gov.identity -> gov.ejbca: REST API (PKI)
gov.identity -> gov.ejbca-rest-secret: keystore + truststore + passwords
gov.ejbca-rest-secret -> ext.gcp-sm: ExternalSecret
gov.authn -> gov.keycloak: OIDC
gov.users-roles -> gov.keycloak: OIDC
gov.identity -> gov.keycloak: OIDC
gov.authn -> gov.redis: cache

# ==========================
# Gateway + frontend
# ==========================
gov.frontend -> gov.tier1: API (window.env)
gov.tier1 -> gov.authn: routes
gov.tier1 -> gov.users-roles: routes
gov.tier1 -> gov.onboarding: routes
gov.tier1 -> gov.identity: routes
gov.tier1 -> gov.sap: routes
gov.tier1 -> gov.adapter: routes
gov.tier2gw -> gov.tier2px: tier2 routes

# ==========================
# Image registry coupling (EC private)
# ==========================
gov.adapter -> ext.ec-registry: pulls image
gov.authn -> ext.ec-registry: pulls image
gov.identity -> ext.ec-registry: pulls image
gov.onboarding -> ext.ec-registry: pulls image
gov.sap -> ext.ec-registry: pulls image
gov.users-roles -> ext.ec-registry: pulls image
gov.tier1 -> ext.ec-registry: pulls image
gov.tier2gw -> ext.ec-registry: pulls image
gov.tier2px -> ext.ec-registry: pulls image
gov.frontend -> ext.ec-registry: pulls image
gov.fc-service -> ext.ec-registry: pulls image
gov.schema-mgr -> ext.ec-registry: pulls image
common.icm -> ext.ec-registry: pulls image
common.notification -> ext.ec-registry: pulls image
common.openbao-config -> ext.ec-registry: pulls image

# ==========================
# Helm chart sources
# ==========================
ext.ec-charts -> common.kafka: helm chart
ext.ec-charts -> common.icm: helm chart
ext.ec-charts -> common.notification: helm chart
ext.ghcr -> common.openbao-config: helm chart
ext.ec-charts -> gov.adapter: helm chart
ext.ec-charts -> gov.identity: helm chart
ext.ec-charts -> gov.authn: helm chart
ext.ec-charts -> gov.onboarding: helm chart
ext.ec-charts -> gov.sap: helm chart
ext.ec-charts -> gov.users-roles: helm chart
ext.ec-charts -> gov.tier1: helm chart
ext.ec-charts -> gov.tier2gw: helm chart
ext.ec-charts -> gov.tier2px: helm chart
ext.ec-charts -> gov.frontend: helm chart
ext.ec-charts -> gov.fc-service: helm chart
ext.ec-charts -> gov.schema-mgr: helm chart

# ==========================
# Bridge-secrets fan-out (Postgres credentials)
# ==========================
common.bridge-secrets -> gov.identity: pg credentials secret
common.bridge-secrets -> gov.authn: pg credentials secret
common.bridge-secrets -> gov.onboarding: pg credentials secret
common.bridge-secrets -> gov.sap: pg credentials secret
common.bridge-secrets -> gov.users-roles: pg credentials secret
common.bridge-secrets -> gov.keycloak: pg credentials secret
common.bridge-secrets -> gov.fc-service: pg credentials secret
common.bridge-secrets -> gov.ejbca: pg credentials secret
