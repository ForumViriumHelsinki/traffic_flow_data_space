    }
  }, {
    "task": "JavaScriptTask",
    "taskId": "5",
    "parameters": {
      "javaScriptEngine": {
        "key": "javaScriptEngine",
        "value": {
          "stringValue": "V8"
        }
      },
      "script": {
        "key": "script",
        "value": {
          "stringValue": "function executeScript(event) {\n  var hsyCurrentJson \u003d event.getParameter(\"HSY-current-json\");\n  var hsyStation \u003d event.getParameter(\"hsy-station\");\n  var features \u003d hsyCurrentJson.features;\n  var airQualityValue \u003d null;\n\n  if (features \u0026\u0026 Array.isArray(features)) {\n    for (var i \u003d 0; i \u003c features.length; i++) {\n      var feature \u003d features[i];\n      if (feature.properties \u0026\u0026 feature.properties.Mittausasema \u003d\u003d\u003d hsyStation) {\n        airQualityValue \u003d feature.properties.Ilmanlaatuindeksi;\n        break;\n      }\n    }\n  }\n\n  if (airQualityValue !\u003d\u003d null) {\n    event.setParameter(\"CurrentAirQualityValue\", airQualityValue);\n  } else {\n    event.log(\"No matching station found or Ilmanlaatuindeksi is null.\");\n  }\n}"
        }
