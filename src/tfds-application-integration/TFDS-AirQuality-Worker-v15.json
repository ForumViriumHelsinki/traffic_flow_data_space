        }
      },
      "script": {
        "key": "script",
        "value": {
          "stringValue": "/**\n * Function that is called during the JavaScript Task execution.\n * @param {IntegrationEvent} event\n */\nfunction executeScript(event) {\n  // Get the response header from the event.\n  var responseHeader \u003d event.getParameter(\"influxStringCurrent\");\n\n  // Check if the responseHeader is not null or empty.\n  if (responseHeader) {\n    try {\n      // Parse the CSV response header to JSON.\n      var jsonResponseHeader \u003d csvToJson(responseHeader);\n\n      // Set the parsed JSON response header to the event.\n      event.setParameter(\"influxJSONCurrent\", jsonResponseHeader);\n    } catch (error) {\n      // Log the error message.\n      event.log(\"Error parsing CSV to JSON: \" + error.message);\n    }\n  } else {\n    // Log a message if the response header is null or empty.\n    event.log(\"Response header is null or empty.\");\n  }\n\n  /**\n   * Function to convert CSV data to JSON format.\n   * @param {string} csv CSV data to convert.\n   * @returns {object} JSON object representing the CSV data.\n   */\n  function csvToJson(csv) {\n    const lines \u003d csv.split(\u0027\\n\u0027);\n    const headers \u003d lines[0].split(\u0027,\u0027);\n    const json \u003d [];\n\n    for (let i \u003d 1; i \u003c lines.length; i++) {\n      const data \u003d lines[i].split(\u0027,\u0027);\n      const obj \u003d {};\n\n      for (let j \u003d 0; j \u003c headers.length; j++) {\n        obj[headers[j].trim()] \u003d data[j] ? data[j].trim() : \u0027\u0027;\n      }\n\n      json.push(obj);\n    }\n\n    return json;\n  }\n}"
        }
      }
    },
